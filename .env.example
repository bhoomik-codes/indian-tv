# ─── IndiaStream Environment Configuration ────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# NEVER commit .env to version control.

# ─── Server Ports ─────────────────────────────────────────────────────────────
# Port the CORS proxy server listens on
PROXY_PORT=8081

# Port the static HTTP server listens on
HTTP_PORT=8080

# ─── Playlist ─────────────────────────────────────────────────────────────────
# Source M3U playlist URL used by update_playlist.py
PLAYLIST_URL=https://iptv-org.github.io/iptv/index.m3u

# Local file where working channels are cached
OUTPUT_FILE=public/working.m3u

# ─── Playlist scanner settings ────────────────────────────────────────────────
# Number of parallel threads used to test channels
MAX_WORKERS=300

# Seconds to wait before timing out a channel test
TIMEOUT=3

# ─── Remote CORS Proxy (fallback when local proxy is unavailable) ─────────────
REMOTE_PROXY_URL=https://corsproxy.io/?url=
