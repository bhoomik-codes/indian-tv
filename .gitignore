# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Generated / Runtime Files ────────────────────────────────────────────────
# Cached playlist (large, auto-generated by server/update_playlist.py)
public/working.m3u

# Server logs — kept in logs/ directory; track the dir via .gitkeep, not the files
logs/*.log

# Stale root-level logs (from before the restructure)
proxy.log
http.log

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
pip-wheel-metadata/

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── Linux ────────────────────────────────────────────────────────────────────
*~
.fuse_hidden*
.Trash-*
.nfs*

# ─── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Editors & IDEs ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.sublime-workspace
*.sublime-project
.kilocode/

# ─── Node (if ever used) ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
